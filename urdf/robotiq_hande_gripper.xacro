<?xml version="1.0"?>
<robot xmlns:xacro="http://ros.org/wiki/xacro">
  <!--
    Based on the URDF file by Cristian C Beltran-Hernandez
  -->

  <xacro:include filename="$(find robotiq_hande_description)/urdf/robotiq_hande_gripper.ros2_control.xacro"/>

  <xacro:macro name="robotiq_hande_gripper" params="name prefix parent grip_pos_min grip_pos_max tty baudrate parity data_bits stop_bit slave_id use_fake_hardware coupler_mass:=0.119">
    <!-- ros2_control parameters  -->
    <xacro:robotiq_hande_ros2_control
      name="${name}"
      prefix="${prefix}"
      grip_pos_min="${grip_pos_min}"
      grip_pos_max="${grip_pos_max}"
      tty="${tty}"
      baudrate="${baudrate}"
      parity="${parity}"
      data_bits="${data_bits}"
      stop_bit="${stop_bit}"
      slave_id="${slave_id}"
      use_fake_hardware="${use_fake_hardware}"
    />

    <!-- Robotiq Coupler -->
    <!--  + Height added by the coupler (16.9mm) -->
    <!--  + Reference frame at the middle (6.95mm) -->
    <!--  + Coupler mass includes the bolts -->

    <xacro:arg name="base_joint_z_offset" default="0.055"/>
    <xacro:arg name="coupler_depth" default="0.00294"/>
    <xacro:arg name="base_to_coupler_offset" default="0.00145"/>

    <joint name="${prefix}robotiq_hande_coupler_joint" type="fixed">
      <origin xyz="0 0 0.00695" rpy="0 0 ${-pi/2.0}"/>
      <parent link="${parent}"/>
      <child link="${prefix}robotiq_hande_coupler"/>
    </joint>

    <link name="${prefix}robotiq_hande_coupler">
      <visual>
        <geometry>
          <mesh filename="package://robotiq_hande_description/meshes/io_coupler.dae"/>
        </geometry>
      </visual>

      <collision>
        <geometry>
          <cylinder length="0.014" radius="0.039"/>
        </geometry>
      </collision>

      <inertial>
        <mass value="${coupler_mass}"/>
        <inertia ixx="6.17674E-5" ixy="0.0" ixz="0.0" iyy="6.17674E-5" iyz="0.0" izz="1.18125E-4"/>
      </inertial>
    </link>

    <joint name="${prefix}robotiq_hande_base_joint" type="fixed">
      <origin xyz="0 0 ${$(arg base_joint_z_offset) + $(arg coupler_depth) - $(arg base_to_coupler_offset)}" rpy="0 0 0"/>
      <parent link="${prefix}robotiq_hande_coupler"/>
      <child link="${prefix}robotiq_hande_link"/>
    </joint>

    <link name="${prefix}robotiq_hande_link">
      <visual>
        <origin xyz="0 0 0" rpy="0 ${-pi/2} 0"/>
        <geometry>
          <mesh filename="package://robotiq_hande_description/meshes/hande.dae" scale="1.0 1.0 1.0"/>
        </geometry>
      </visual>

      <collision>
        <geometry>
          <cylinder length="0.099" radius="0.039"/>
        </geometry>
      </collision>

      <inertial>
        <mass value="0.86387"/>
        <inertia ixx="1E-3" ixy="0.0" ixz="0.0" iyy="1E-3" iyz="0.0" izz="6E-4"/>
      </inertial>
    </link>

    <joint name="${prefix}robotiq_hande_left_finger_joint" type="prismatic">
      <origin xyz="-0.025 0 0.0345" rpy="0 0 0"/>
      <parent link="${prefix}robotiq_hande_link"/>
      <child link="${prefix}robotiq_hande_left_finger"/>
      <axis xyz="1 0 0"/>
      <limit effort="130" lower="${grip_pos_min}" upper="${grip_pos_max}" velocity="0.15"/>
    </joint>

    <link name="${prefix}robotiq_hande_left_finger">
      <visual>
        <origin xyz="0 0 0" rpy="${pi/2} 0 ${pi/2}"/>
        <geometry>
          <mesh filename="package://robotiq_hande_description/meshes/finger.dae" scale="1.0 1.0 1.0"/>
        </geometry>
      </visual>

      <collision>
        <origin xyz="0 0 0" rpy="0 0 ${pi/2}"/>
        <geometry>
          <mesh filename="package://robotiq_hande_description/meshes/finger_collision.dae" scale="1.0 1.0 1.0"/>
        </geometry>
      </collision>

      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <mass value="0.03804"/>
        <inertia ixx="1E-9" ixy="0.0" ixz="0.0" iyy="1E-9" iyz="0.0" izz="1E-9"/>
      </inertial>
    </link>

    <joint name="${prefix}robotiq_hande_right_finger_joint" type="prismatic">
      <origin xyz="0.025 0 0.0345" rpy="0 0 0"/>
      <parent link="${prefix}robotiq_hande_link"/>
      <child link="${prefix}robotiq_hande_right_finger"/>
      <axis xyz="-1 0 0"/>
      <limit effort="130" lower="${grip_pos_min}" upper="${grip_pos_max}" velocity="0.15"/>
      <mimic joint="${prefix}robotiq_hande_left_finger_joint" multiplier="1" offset="0"/>
    </joint>

    <link name="${prefix}robotiq_hande_right_finger">
      <visual>
        <origin xyz="0 0 0" rpy="${pi/2} 0 ${-pi/2}"/>
        <geometry>
          <mesh filename="package://robotiq_hande_description/meshes/finger.dae" scale="1.0 1.0 1.0"/>
        </geometry>
      </visual>

      <collision>
        <origin xyz="0 0 0" rpy="0 0 ${-pi/2}"/>
        <geometry>
          <mesh filename="package://robotiq_hande_description/meshes/finger_collision.dae" scale="1.0 1.0 1.0"/>
        </geometry>
      </collision>

      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <mass value="0.03804"/>
        <inertia ixx="1E-9" ixy="0.0" ixz="0.0" iyy="1E-9" iyz="0.0" izz="1E-9"/>
      </inertial>
    </link>

    <joint name="${prefix}robotiq_hande_end_joint" type="fixed">
      <origin xyz="0 0 0.095" rpy="0 0 0"/>
      <parent link="${prefix}robotiq_hande_link"/>
      <child link="${prefix}robotiq_hande_end"/>
    </joint>

    <link name="${prefix}robotiq_hande_end"/>
  </xacro:macro>
</robot>
